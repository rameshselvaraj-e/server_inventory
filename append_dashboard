      <span class="om-kpi-lbl">Distinct Models</span>
    </div>
    <div class="om-kpi-sep">|</div>
    <div class="om-kpi-item">
      <span class="om-kpi-num">{{ kpi.vram or 0 }}<small> GB</small></span>
      <span class="om-kpi-lbl">Total VRAM</span>
    </div>
  </div>
 
  <!-- Two-column: Owner cards + Model cards -->
  <div class="om-split">
 
    <!-- ── Owner cards ──────────────────────────────────────── -->
    <div class="om-panel">
      <div class="om-panel-header">
        <span class="om-panel-icon">👤</span>
        <span class="om-panel-title">By Owner / Team</span>
        <span class="om-panel-count">{{ owner_rows|length }}</span>
