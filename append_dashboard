.gpu-dashboard { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }

/* ── KPI Row ─────────────────────────────────────────────────────────────── */
.gpu-kpi-row {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
}

.gpu-kpi-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
