  align-items: center;
  gap: 14px;
  transition: border-color 0.15s, transform 0.15s;
}
.gpu-kpi-card:hover { transform: translateY(-1px); }
.gpu-kpi-card.kpi-alert {
  border-color: rgba(248,81,73,0.5);
  background: rgba(248,81,73,0.04);
  animation: pulse-border 2s infinite;
}
@keyframes pulse-border {
  0%,100% { border-color: rgba(248,81,73,0.5); }
  50%      { border-color: rgba(248,81,73,0.9); }
}

.kpi-icon { font-size: 22px; flex-shrink: 0; }
.kpi-value { font-size: 26px; font-weight: 800; line-height: 1; letter-spacing: -1px; }
.kpi-unit  { font-size: 13px; font-weight: 600; margin-left: 2px; opacity: 0.7; }
.kpi-label { font-size: 11px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; color: var(--muted); margin-top: 4px; }

