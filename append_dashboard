<div class="filter-bar">
  <form method="get" class="filter-form">
    <input type="text" name="search" value="{{ search }}" placeholder="Search GPU name, model, host, assigned to..." class="filter-input"/>
    <select name="status" class="filter-select">
      <option value="">All Status</option>
      <option value="active"         {% if status=='active' %}selected{% endif %}>Active</option>
      <option value="inactive"       {% if status=='inactive' %}selected{% endif %}>Inactive</option>
      <option value="faulty"         {% if status=='faulty' %}selected{% endif %}>Faulty</option>
      <option value="maintenance"    {% if status=='maintenance' %}selected{% endif %}>Maintenance</option>
      <option value="decommissioned" {% if status=='decommissioned' %}selected{% endif %}>Decommissioned</option>
    </select>
    <button type="submit" class="btn-filter">Filter</button>
    <a href="{{ url_for('gpu_list') }}" class="btn-reset">Reset</a>
    <a href="{{ url_for('gpu_dash') }}" class="btn-filter">Dashboard</a>
  </form>
</div>


