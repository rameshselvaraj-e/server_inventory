</div>
 
<script>
// Auto-submit on typing with debounce
['ownerInput','modelInput'].forEach(function(id) {
  var el = document.getElementById(id);
  if (!el) return;
  var timer;
  el.addEventListener('input', function() {
    clearTimeout(timer);
    timer = setTimeout(function() {
      document.getElementById('omSearchForm').submit();
    }, 500);
  });
});
</script>
