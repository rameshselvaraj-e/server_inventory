        <a href="{{ url_for('gpu_list') }}" class="om-reset-btn">Reset</a>
      {% endif %}
    </div>
 
    <!-- Active filter pills -->
    {% if owner_search or model_search %}
    <div class="om-active-filters">
      {% if owner_search %}
        <span class="filter-pill pill-owner">👤 {{ owner_search }}</span>
      {% endif %}
      {% if model_search %}
        <span class="filter-pill pill-model">◧ {{ model_search }}</span>
      {% endif %}
