# GPU INVENTORY
# ═══════════════════════════════════════════════════════════════════════════════
@app.route('/gpu')
def gpu_list():
    search       = request.args.get('search', '').strip()
    owner_search = request.args.get('owner_search', '').strip()
    model_search = request.args.get('model_search', '').strip()
    status       = request.args.get('status', '')
 
    # Full inventory table
    sql = "SELECT * FROM gpu_inventory WHERE 1=1"
    params = []
    if search:
        sql += " AND (gpu_name LIKE %s OR manufacturer LIKE %s OR model LIKE %s OR host_server LIKE %s OR assigned_to LIKE %s)"
        params += ['%'+search+'%'] * 5
    if status:
        sql += " AND status=%s"
        params.append(status)
    sql += " ORDER BY created_at DESC"
    rows = query(sql, params)
 
    # Owner/Model dashboard filter
    dash_conds  = ["assigned_to IS NOT NULL", "assigned_to != ''"]
    dash_params = []
    if owner_search:
        dash_conds.append("assigned_to LIKE %s")
        dash_params.append('%'+owner_search+'%')
    if model_search:
        dash_conds.append("model LIKE %s")
        dash_params.append('%'+model_search+'%')
    dash_where = "WHERE " + " AND ".join(dash_conds)
 
    owner_sql = (
        "SELECT assigned_to AS owner, COUNT(*) AS total_gpus, "
        "SUM(CASE WHEN status='active' THEN 1 ELSE 0 END) AS active_gpus, "
        "GROUP_CONCAT(DISTINCT model ORDER BY model SEPARATOR ', ') AS models, "
        "GROUP_CONCAT(DISTINCT manufacturer ORDER BY manufacturer SEPARATOR ', ') AS manufacturers, "
        "GROUP_CONCAT(DISTINCT environment ORDER BY environment SEPARATOR ', ') AS environments, "
        "COALESCE(SUM(vram_gb),0) AS total_vram, "
        "COALESCE(SUM(tdp_watts),0) AS total_tdp "
        "FROM gpu_inventory " + dash_where + " "
        "GROUP BY assigned_to ORDER BY total_gpus DESC"
    )
    owner_rows = query(owner_sql, dash_params or None) or []
 
    model_sql = (
        "SELECT model, manufacturer, COUNT(*) AS total_gpus, "
        "SUM(CASE WHEN status='active' THEN 1 ELSE 0 END) AS active_gpus, "
        "GROUP_CONCAT(DISTINCT assigned_to ORDER BY assigned_to SEPARATOR ', ') AS owners, "
        "COALESCE(MAX(vram_gb),0) AS vram_gb, "
        "COALESCE(MAX(cuda_cores),0) AS cuda_cores, "
        "COALESCE(MAX(tensor_cores),0) AS tensor_cores, "
        "COALESCE(MAX(tdp_watts),0) AS tdp_watts "
        "FROM gpu_inventory " + dash_where + " "
        "GROUP BY model, manufacturer ORDER BY total_gpus DESC"
    )
    model_rows = query(model_sql, dash_params or None) or []
 
    kpi_sql = (
        "SELECT COUNT(*) AS total, COALESCE(SUM(vram_gb),0) AS vram, "
        "COUNT(DISTINCT assigned_to) AS owners, COUNT(DISTINCT model) AS models "
        "FROM gpu_inventory " + dash_where
    )
    kpi = query(kpi_sql, dash_params or None, fetchone=True) or {}
 
    all_owners = query("SELECT DISTINCT assigned_to FROM gpu_inventory WHERE assigned_to IS NOT NULL AND assigned_to != '' ORDER BY assigned_to") or []
    all_models = query("SELECT DISTINCT model, manufacturer FROM gpu_inventory WHERE model IS NOT NULL AND model != '' ORDER BY model") or []
 
    def _q(s, p=None): return query(s, p, fetchone=True) or {}
    gpu_stats = {
        'total':         (_q("SELECT COUNT(*) as c FROM gpu_inventory"))['c'],
        'active':        (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE status='active'"))['c'],
        'faulty':        (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE status='faulty'"))['c'],
        'maintenance':   (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE status='maintenance'"))['c'],
        'inactive':      (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE status='inactive'"))['c'],
        'decommissioned':(_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE status='decommissioned'"))['c'],
        'total_vram_gb': (_q("SELECT COALESCE(SUM(vram_gb),0) as c FROM gpu_inventory WHERE status NOT IN ('decommissioned')"))['c'],
        'total_tdp_kw':  (_q("SELECT COALESCE(ROUND(SUM(tdp_watts)/1000,1),0) as c FROM gpu_inventory WHERE status='active'"))['c'],
        'nvidia_count':  (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE manufacturer='NVIDIA'"))['c'],
        'amd_count':     (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE manufacturer='AMD'"))['c'],
        'intel_count':   (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE manufacturer='Intel'"))['c'],
        'prod_count':    (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE environment='production'"))['c'],
        'dev_count':     (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE environment='development'"))['c'],
        'staging_count': (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE environment='staging'"))['c'],
        'test_count':    (_q("SELECT COUNT(*) as c FROM gpu_inventory WHERE environment='testing'"))['c'],
        'purpose_breakdown': query("SELECT purpose, COUNT(*) as cnt FROM gpu_inventory WHERE purpose IS NOT NULL AND purpose != '' GROUP BY purpose ORDER BY cnt DESC LIMIT 6") or [],
        'host_breakdown': query("SELECT host_server, COUNT(*) as cnt, SUM(vram_gb) as total_vram FROM gpu_inventory WHERE host_server IS NOT NULL AND host_server != '' GROUP BY host_server ORDER BY cnt DESC LIMIT 6") or [],
        'recent': query("SELECT gpu_name, manufacturer, model, vram_gb, status, created_at FROM gpu_inventory ORDER BY created_at DESC LIMIT 5") or [],
    }
 
    return render_template(
        'gpu/list.html',
        rows=rows, search=search, status=status,
        gpu_stats=gpu_stats,
        owner_rows=owner_rows, model_rows=model_rows, kpi=kpi,
        owner_search=owner_search, model_search=model_search,
        all_owners=all_owners, all_models=all_models,
    )
