<div class="om-dashboard">
 
  <!-- Search bar -->
  <form method="get" class="om-search-form" id="omSearchForm">
    <div class="om-search-wrap">
      <div class="om-search-group">
        <span class="om-search-icon">👤</span>
        <input
          type="text"
          name="owner_search"
          id="ownerInput"
          value="{{ owner_search }}"
          placeholder="Search by owner / team…"
          class="om-search-input"
          autocomplete="off"
          list="ownerList"
        />
        <datalist id="ownerList">
          {% for o in all_owners %}
            <option value="{{ o.assigned_to }}">
          {% endfor %}
        </datalist>
        {% if owner_search %}
          <a href="{{ url_for('gpu_list', model_search=model_search) }}" class="om-clear-btn" title="Clear owner">✕</a>
        {% endif %}
      </div>
 
      <div class="om-search-divider">+</div>
 
      <div class="om-search-group">
        <span class="om-search-icon">◧</span>
        <input
          type="text"
          name="model_search"
          id="modelInput"
          value="{{ model_search }}"
          placeholder="Search by GPU model…"
          class="om-search-input"
          autocomplete="off"
          list="modelList"
        />
        <datalist id="modelList">
          {% for m in all_models %}
            <option value="{{ m.model }}">
          {% endfor %}
        </datalist>
        {% if model_search %}
          <a href="{{ url_for('gpu_list', owner_search=owner_search) }}" class="om-clear-btn" title="Clear model">✕</a>
